{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-checks.sh",
            "timeout": 120,
            "statusMessage": "Running Rubocop and tests..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(gh repo:*)",
      "Bash(gh issue:*)",
      "Bash(ls:*)",
      "Bash(bundle install:*)",
      "Bash(bundle list:*)",
      "Bash(bin/rails tailwindcss:install:*)",
      "Bash(bin/rails action_text:install:*)",
      "Bash(bin/rails db:prepare:*)",
      "Bash(bin/rails test:*)",
      "Bash(bundle show:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "Bash(ruby:*)",
      "Bash(bin/rubocop:*)",
      "Bash(bin/brakeman:*)",
      "Bash(bin/rails tailwindcss:build:*)",
      "Bash(cat:*)",
      "Bash(bin/rails db:schema:dump:*)"
    ]
  }
}
