<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "OSSVolunteers — Open Source Volunteer Opportunities" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="OSSVolunteers">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="Connect with open-source projects that need your skills. Find volunteer opportunities in engineering, design, marketing, and more.">
    <meta name="author" content="OSSVolunteers">
    <meta name="robots" content="index, follow">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <script defer src="https://cloud.umami.is/script.js" data-website-id="c82e27f6-eb2b-480a-980a-78cb43a673f9"></script>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= Sentry.get_trace_propagation_meta.html_safe %>
  </head>

  <body class="min-h-screen flex flex-col bg-gray-50">
    <nav class="bg-white shadow-sm sticky top-0 z-50" data-controller="nav">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <%# Left side: logo and primary nav %>
          <div class="flex items-center">
            <%= link_to root_path, class: "flex items-center gap-2 shrink-0 group" do %>
              <span class="text-slate-800 press-start-2p">OSS<span class="text-amber-600">Volunteers</span></span>
            <% end %>
            <div class="hidden sm:flex sm:ml-8 sm:space-x-4">
              <%= link_to "Home", root_path, class: "text-gray-700 hover:text-amber-600 px-3 py-2 text-sm font-medium rounded-md hover:bg-gray-100" %>
              <%= link_to "Listings", listings_path, class: "text-gray-700 hover:text-amber-600 px-3 py-2 text-sm font-medium rounded-md hover:bg-gray-100" %>
              <%= link_to "Organizations", organizations_path, class: "text-gray-700 hover:text-amber-600 px-3 py-2 text-sm font-medium rounded-md hover:bg-gray-100" %>
            </div>
          </div>

          <%# Right side: auth links %>
          <div class="hidden sm:flex sm:items-center sm:space-x-2">
            <% if authenticated? %>
              <% if Current.user&.site_admin? %>
                <%= link_to "Admin", admin_root_path, class: "text-gray-700 hover:text-amber-600 px-3 py-2 text-sm font-medium rounded-md hover:bg-gray-100" %>
              <% end %>
              <div class="relative ml-2" data-controller="dropdown">
                <button type="button" data-action="click->dropdown#toggle" class="flex items-center text-sm font-medium text-gray-700 hover:text-amber-600 px-3 py-2 rounded-md hover:bg-gray-100">
                  <%= Current.user.name %>
                  <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </button>
                <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-48 bg-white rounded-md shadow-lg ring-1 ring-gray-300 ring-opacity-5 py-1 z-50">
                  <%= link_to "My Organizations", profile_organizations_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                  <%= link_to "Applied Listings", profile_listings_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                  <%= link_to "Edit Profile", edit_profile_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                  <%= button_to "Sign Out", session_path, method: :delete, class: "block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                </div>
              </div>
            <% else %>
              <%= link_to "Sign In", new_session_path, class: "text-gray-700 hover:text-amber-600 px-3 py-2 text-sm font-medium rounded-md hover:bg-gray-100" %>
              <%= link_to "Sign Up", new_registration_path, class: "bg-slate-800 text-white hover:bg-slate-700 px-4 py-2 text-sm font-medium rounded-md" %>
            <% end %>
          </div>

          <%# Mobile hamburger button %>
          <div class="flex items-center sm:hidden">
            <button type="button" data-action="click->nav#toggle" class="inline-flex items-center justify-center p-2 rounded-md text-gray-500 hover:text-gray-700 hover:bg-gray-100" aria-label="Toggle navigation">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <%# Mobile menu %>
      <div class="hidden sm:hidden" data-nav-target="menu">
        <div class="px-2 pt-2 pb-3 space-y-1">
          <%= link_to "Home", root_path, class: "block text-gray-700 hover:text-amber-600 px-3 py-2 text-base font-medium rounded-md hover:bg-gray-100" %>
          <%= link_to "Listings", listings_path, class: "block text-gray-700 hover:text-amber-600 px-3 py-2 text-base font-medium rounded-md hover:bg-gray-100" %>
          <%= link_to "Organizations", organizations_path, class: "block text-gray-700 hover:text-amber-600 px-3 py-2 text-base font-medium rounded-md hover:bg-gray-100" %>
          <% if authenticated? %>
            <% if Current.user&.site_admin? %>
              <%= link_to "Admin", admin_root_path, class: "block text-gray-700 hover:text-amber-600 px-3 py-2 text-base font-medium rounded-md hover:bg-gray-100" %>
            <% end %>
            <%= link_to "My Organizations", profile_organizations_path, class: "block text-gray-700 hover:text-amber-600 px-3 py-2 text-base font-medium rounded-md hover:bg-gray-100" %>
            <%= link_to "Edit Profile", edit_profile_path, class: "block text-gray-700 hover:text-amber-600 px-3 py-2 text-base font-medium rounded-md hover:bg-gray-100" %>
            <%= button_to "Sign Out", session_path, method: :delete, class: "block w-full text-left text-gray-700 hover:text-amber-600 px-3 py-2 text-base font-medium rounded-md hover:bg-gray-100" %>
          <% else %>
            <%= link_to "Sign In", new_session_path, class: "block text-gray-700 hover:text-amber-600 px-3 py-2 text-base font-medium rounded-md hover:bg-gray-100" %>
            <%= link_to "Sign Up", new_registration_path, class: "block text-amber-600 hover:text-amber-700 px-3 py-2 text-base font-medium rounded-md hover:bg-gray-100" %>
          <% end %>
        </div>
      </div>
    </nav>

    <% if authenticated? && Current.user && !Current.user.email_confirmed? %>
      <div class="bg-yellow-50 border-b border-yellow-200 px-4 py-3 text-center text-sm text-yellow-800">
        Please confirm your email address.
        <%= button_to "Resend confirmation email", email_confirmations_path, method: :post, class: "underline font-medium" %>
      </div>
    <% end %>

    <%# Flash messages %>
    <%= render FlashComponent.new(flash: flash) %>

    <% if content_for?(:main_content) %>
      <main class="flex-1">
        <%= yield(:main_content) %>
      </main>
    <% else %>
      <main class="flex-1 max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <%= yield %>
      </main>
    <% end %>

    <footer class="bg-slate-900 mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <div>
            <span class="text-white press-start-2p">OSS<span class="text-amber-500">Volunteers</span></span>
            <p class="text-slate-400 text-sm mt-1">Connecting talent with open source.</p>
          </div>
          <div class="text-sm text-slate-500">
            <p>Site &copy; <%= Date.current.year %> OSSVolunteers.com</p>
            <p>Hero image adapted from <a href="https://unsplash.com/@windows?utm_source=unsplash&utm_medium=referral&utm_content=creditCopyText">Windows</a> on <a href="https://unsplash.com/photos/men-and-women-sitting-and-standing-while-staring-at-laptop-p74ndnYWRY4?utm_source=unsplash&utm_medium=referral&utm_content=creditCopyText">Unsplash</a></p>
            <p>All other content &copy; its owners.</p>
            <p class="mt-1"><%= link_to "Terms of Service", terms_path, class: "text-slate-400 hover:text-slate-300" %> · <%= link_to "Privacy Policy", privacy_path, class: "text-slate-400 hover:text-slate-300" %></p>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
