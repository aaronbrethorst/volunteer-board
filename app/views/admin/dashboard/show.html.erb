<% content_for(:title, "Admin Dashboard") %>

<div class="w-full">
  <h1 class="text-2xl font-bold mb-6">Admin Dashboard</h1>

  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-sm font-medium text-gray-500">Organizations</h2>
      <p class="text-3xl font-bold mt-2"><%= @organizations_count %></p>
      <p class="text-sm text-gray-400 mt-1"><%= @discarded_organizations_count %> discarded</p>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-sm font-medium text-gray-500">Listings</h2>
      <p class="text-3xl font-bold mt-2"><%= @listings_count %></p>
      <p class="text-sm text-gray-400 mt-1"><%= @discarded_listings_count %> discarded</p>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-sm font-medium text-gray-500">Users</h2>
      <p class="text-3xl font-bold mt-2"><%= @users_count %></p>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-sm font-medium text-gray-500">Unreviewed Flags</h2>
      <p class="text-3xl font-bold mt-2"><%= @unreviewed_flags_count %></p>
    </div>
  </div>
</div>
