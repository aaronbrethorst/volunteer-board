<div class="w-full max-w-5xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">My Organizations</h1>
      <p class="text-gray-500 text-sm mt-1">Organizations you belong to.</p>
    </div>
    <%= link_to "New Organization", new_organization_path, class: "link-button" %>
  </div>

  <% if @organizations.any? %>
    <div class="space-y-6">
      <% @organizations.each do |organization| %>
        <div class="bg-white shadow rounded-lg p-6">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
              <%= render OrganizationLogoComponent.new(organization: organization, size: :md) %>
              <h2 class="text-xl font-semibold">
                <%= link_to organization.name, organization_path(organization.slug), class: "link" %>
              </h2>
            </div>
            <% membership = Current.user.memberships.find_by(organization: organization) %>
            <% if membership&.owner? %>
              <div class="flex items-center gap-2">
                <%= link_to "New Listing", new_organization_listing_path(organization.slug), class: "link-button" %>
                <%= link_to "Edit Organization", edit_organization_path(organization.slug), class: "link-button" %>
              </div>
            <% end %>
          </div>

          <% kept_listings = organization.listings.reject(&:discarded?) %>
          <% if kept_listings.any? %>
            <div class="mt-5">
              <table class="w-full text-sm">
                <thead>
                  <tr class="text-left text-gray-500 border-b border-gray-200">
                    <th class="pb-2 font-medium">Listing</th>
                    <th class="pb-2 font-medium">Status</th>
                    <th class="pb-2 font-medium">Applications</th>
                    <th class="pb-2 font-medium">Created</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                  <% kept_listings.each do |listing| %>
                    <tr>
                      <td class="py-2.5">
                        <%= link_to listing.title, listing_path(listing), class: "link" %>
                      </td>
                      <td class="py-2.5">
                        <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                          <%= case listing.status
                              when 'open' then 'bg-green-100 text-green-800'
                              when 'filled' then 'bg-yellow-100 text-yellow-800'
                              when 'closed' then 'bg-red-100 text-red-800'
                              end %>">
                          <%= listing.status.titleize %>
                        </span>
                      </td>
                      <td class="py-2.5 text-gray-600">
                        <%= listing.interests.size %> <%= "application".pluralize(listing.interests.size) %>
                      </td>
                      <td class="py-2.5 text-gray-500">
                        <%= listing.created_at.strftime("%b %-d, %Y") %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <p class="mt-4 text-sm text-gray-400">No listings yet.</p>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 border-2 border-dashed border-gray-200 rounded-xl">
      <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/></svg>
      <p class="text-gray-500 text-lg mt-4">No organizations yet.</p>
      <p class="text-gray-400 text-sm mt-1"><%= link_to "Create one", new_organization_path, class: "link" %> to get started.</p>
    </div>
  <% end %>
</div>
