<%= form_with(model: organization, url: url, method: method, class: "space-y-6") do |form| %>
  <% if organization.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4">
      <h2 class="text-red-800 font-semibold mb-2"><%= pluralize(organization.errors.count, "error") %> prevented this organization from being saved:</h2>
      <ul class="list-disc list-inside text-red-700 text-sm">
        <% organization.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "form-label" %>
    <%= form.text_field :name, class: "form-control" %>
  </div>

  <div>
    <%= form.label :description, class: "form-label" %>
    <%= form.text_area :description, rows: 5, class: "form-control" %>
  </div>

  <div>
    <%= form.label :website_url, "Website URL", class: "form-label" %>
    <%= form.url_field :website_url, class: "form-control", placeholder: "https://yourorg.com" %>
  </div>

  <div>
    <%= form.label :repo_url, "Repository URL", class: "form-label" %>
    <%= form.url_field :repo_url, class: "form-control", placeholder: "https://github.com/yourorg" %>
  </div>

  <div>
    <%= form.label :logo, class: "form-label" %>
    <%= form.file_field :logo, accept: "image/*", class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
  </div>

  <div class="flex items-center gap-4">
    <%= form.submit class: "bg-indigo-600 text-white px-4 py-2 rounded-md hover:bg-indigo-700 transition cursor-pointer" %>
    <% if organization.persisted? %>
      <%= link_to "Cancel", organization_path(organization.slug), class: "text-gray-600 hover:text-gray-800" %>
    <% end %>
  </div>
<% end %>
