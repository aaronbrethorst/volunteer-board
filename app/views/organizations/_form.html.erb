<%= form_with(model: organization, url: url, method: method, class: "space-y-6") do |form| %>
  <% if organization.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4">
      <h2 class="text-red-800 font-semibold mb-2"><%= pluralize(organization.errors.count, "error") %> prevented this organization from being saved:</h2>
      <ul class="list-disc list-inside text-red-700 text-sm">
        <% organization.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= render ::Form::TextFieldComponent.new(form: form, attribute: :name) %>
  <%= render ::Form::TextAreaComponent.new(form: form, attribute: :description, rows: 5) %>
  <%= render ::Form::UrlFieldComponent.new(form: form, attribute: :website_url, label: "Website URL", placeholder: "https://yourorg.com") %>
  <%= render ::Form::UrlFieldComponent.new(form: form, attribute: :repo_url, label: "Repository URL", placeholder: "https://github.com/yourorg") %>
  <%= render ::Form::FileFieldComponent.new(form: form, attribute: :logo, accept: "image/*") %>

  <div class="flex items-center gap-4">
    <%= render ::Form::SubmitButtonComponent.new(form: form) %>
    <% if organization.persisted? %>
      <%= link_to "Cancel", organization_path(organization.slug), class: "text-gray-600 hover:text-gray-800" %>
    <% end %>
  </div>
<% end %>
