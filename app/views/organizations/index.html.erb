<div class="w-full max-w-4xl mx-auto">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Organizations</h1>
    <% if authenticated? %>
      <%= link_to "New Organization", new_organization_path, class: "link-button" %>
    <% end %>
  </div>

  <div class="space-y-4">
    <% @organizations.each do |organization| %>
      <%= link_to organization_path(organization.slug), class: "group block bg-white shadow rounded-lg p-6 hover:shadow-md hover:border-gray-300 transition-all duration-200" do %>
        <div class="flex items-center gap-4">
          <%= render OrganizationLogoComponent.new(organization: organization, size: :md) %>

          <div class="flex-1 min-w-0">
            <h2 class="text-xl font-semibold text-gray-900 group-hover:text-amber-700 transition-colors">
              <%= organization.name %>
            </h2>
            <% if organization.description.present? %>
              <p class="text-gray-600 text-sm mt-1"><%= truncate(organization.description, length: 150) %></p>
            <% end %>
          </div>

          <% count = organization.active_listings_count.to_i %>
          <div class="text-right shrink-0 pl-4">
            <span class="text-3xl font-bold <%= count > 0 ? 'text-amber-600' : 'text-gray-300' %>"><%= count %></span>
            <p class="text-xs text-gray-400 mt-0.5"><%= "listing".pluralize(count) %></p>
          </div>
        </div>
      <% end %>
    <% end %>

    <% if @organizations.empty? %>
      <p class="text-gray-500 text-center py-8">No organizations yet.</p>
    <% end %>
  </div>

  <% if @pagy.last > 1 %>
    <div class="mt-8">
      <%== @pagy.series_nav(id: "organizations-pagination", aria_label: "Organizations pagination") %>
    </div>
  <% end %>
</div>
