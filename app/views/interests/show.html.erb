<div class="w-full max-w-3xl mx-auto">
  <% volunteer = @interest.user %>

  <%# === Hero card === %>
  <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-slate-800 via-slate-900 to-slate-950 p-8 sm:p-10">
    <div class="absolute inset-0 opacity-[0.07]" style="background-image: radial-gradient(circle at 20% 50%, rgb(251 191 36) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgb(251 191 36) 0%, transparent 40%);"></div>

    <div class="relative flex flex-col sm:flex-row items-start gap-6">
      <%# Avatar %>
      <div class="w-20 h-20 rounded-full bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center shadow-lg ring-4 ring-white/10 shrink-0">
        <span class="text-2xl font-bold text-slate-900"><%= volunteer.name.first.upcase %></span>
      </div>

      <div class="flex-1 min-w-0">
        <h1 class="text-2xl sm:text-3xl font-bold text-white tracking-tight"><%= volunteer.name %></h1>

        <p class="mt-1 text-sm text-slate-400">
          Expressed interest in
          <%= link_to @listing.title, listing_path(@listing), class: "text-amber-400 hover:text-amber-300 transition-colors" %>
          &middot;
          <%= time_ago_in_words(@interest.created_at) %> ago
        </p>

        <%# Contact & links %>
        <div class="flex flex-wrap items-center gap-2 mt-4">
          <a href="mailto:<%= volunteer.email_address %>"
             class="inline-flex items-center gap-1.5 rounded-full bg-white/10 hover:bg-white/20 border border-white/10 px-3.5 py-1.5 text-sm font-medium text-slate-200 transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/></svg>
            <%= volunteer.email_address %>
          </a>

          <% if volunteer.github_username.present? %>
            <a href="https://github.com/<%= volunteer.github_username %>" target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-1.5 rounded-full bg-white/10 hover:bg-white/20 border border-white/10 px-3.5 py-1.5 text-sm font-medium text-slate-200 transition-colors">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              <%= volunteer.github_username %>
            </a>
          <% end %>

          <% if (safe_url = safe_external_url(volunteer.portfolio_url)) %>
              <a href="<%= safe_url %>" target="_blank" rel="noopener noreferrer"
                 class="inline-flex items-center gap-1.5 rounded-full bg-white/10 hover:bg-white/20 border border-white/10 px-3.5 py-1.5 text-sm font-medium text-slate-200 transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
                Portfolio
              </a>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# === Body content === %>
  <div class="mt-6 space-y-6">
    <%# Bio %>
    <% if volunteer.bio.present? %>
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 sm:p-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-3">About</h2>
        <p class="text-gray-700 leading-relaxed whitespace-pre-wrap"><%= volunteer.bio %></p>
      </div>
    <% end %>

    <%# Message %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 sm:p-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">Message</h2>
      <% if @interest.message.present? %>
        <p class="text-gray-700 leading-relaxed whitespace-pre-wrap"><%= @interest.message %></p>
      <% else %>
        <p class="text-gray-400 italic">No message provided.</p>
      <% end %>
    </div>

    <%# Navigation %>
    <div class="flex items-center justify-between">
      <%= link_to listing_path(@listing),
          class: "inline-flex items-center gap-1.5 text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/></svg>
        Back to listing
      <% end %>

      <a href="mailto:<%= volunteer.email_address %>"
         class="inline-flex items-center gap-1.5 rounded-lg bg-slate-800 hover:bg-slate-700 px-4 py-2 text-sm font-medium text-white shadow-sm transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/></svg>
        Contact <%= volunteer.name.split.first %>
      </a>
    </div>
  </div>
</div>
