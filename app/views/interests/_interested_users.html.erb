<% if listing.interested_users.any? %>
  <div class="border-t mt-8 pt-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-3">Interested Volunteers</h2>
    <ul class="space-y-2">
      <% listing.interested_users.each do |user| %>
        <li class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center">
            <span class="text-sm font-bold text-indigo-600"><%= user.name.first.upcase %></span>
          </div>
          <%= link_to user.name, user_path(user), class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
          <span class="text-xs text-gray-500">
            expressed interest <%= time_ago_in_words(user.interests.find_by(listing: listing).created_at) %> ago
          </span>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>
