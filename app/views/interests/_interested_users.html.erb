<% if interests.any? %>
  <div class="border-t mt-8 pt-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-3">Interested Volunteers</h2>
    <ul class="space-y-2">
      <% interests.each do |interest| %>
        <li class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center">
            <span class="text-sm font-bold text-indigo-600"><%= interest.user.name.first.upcase %></span>
          </div>
          <%= link_to interest.user.name, user_path(interest.user), class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
          <span class="text-xs text-gray-500">
            expressed interest <%= time_ago_in_words(interest.created_at) %> ago
          </span>
          <%= link_to "View details", listing_interest_detail_path(listing, interest), class: "text-xs text-indigo-500 hover:text-indigo-700 ml-2" %>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>
