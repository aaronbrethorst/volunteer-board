<div class="w-full max-w-4xl mx-auto">
  <div class="mb-8">
    <div class="flex items-center gap-2 text-sm text-gray-500 mb-4">
      <%= link_to @listing.title, listing_path(@listing), class: "link" %>
      <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
      <span class="text-gray-900">Interested Volunteers</span>
    </div>
    <h1 class="text-3xl font-bold text-gray-900">Interested Volunteers</h1>
    <p class="text-gray-500 text-sm mt-1"><%= pluralize(@interests.size, "person") %> interested in <strong><%= @listing.title %></strong></p>
  </div>

  <% if @interests.any? %>
    <div class="space-y-3">
      <% @interests.each do |interest| %>
        <%= link_to listing_interest_detail_path(@listing, interest),
            class: "group block bg-white shadow rounded-lg p-5 hover:shadow-md hover:border-gray-300 transition-all duration-200" do %>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-amber-50 ring-1 ring-amber-200 inline-flex items-center justify-center">
                <span class="text-sm font-bold text-amber-600"><%= interest.user.name.first.upcase %></span>
              </div>
              <div>
                <p class="font-semibold text-gray-900 group-hover:text-amber-700 transition-colors"><%= interest.user.name %></p>
                <p class="text-xs text-gray-500"><%= time_ago_in_words(interest.created_at) %> ago</p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <% if interest.message.present? %>
                <span class="text-xs text-gray-400">Has message</span>
              <% end %>
              <svg class="w-5 h-5 text-gray-300 group-hover:text-amber-500 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 border-2 border-dashed border-gray-200 rounded-xl">
      <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128H5.228A2 2 0 0 1 3.35 17.33a8.01 8.01 0 0 1 1.926-4.564M12 12.75a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm-6.276 4.023a8.07 8.07 0 0 1 .769-1.773M12 12.75c1.384 0 2.63-.498 3.6-1.324"/></svg>
      <p class="text-gray-500 text-lg mt-4">No one has expressed interest yet.</p>
    </div>
  <% end %>
</div>
