<div class="w-full max-w-2xl mx-auto">
  <div class="bg-white shadow rounded-lg p-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-4"><%= @user.name %></h1>

    <% if @user.bio.present? %>
      <div class="mb-6">
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-1">Bio</h2>
        <p class="text-gray-700"><%= @user.bio %></p>
      </div>
    <% end %>

    <% if @user.github_username.present? || @user.linkedin_username.present? || @user.portfolio_url.present? %>
      <div class="mb-6">
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Links</h2>
        <ul class="space-y-2">
          <% if @user.github_username.present? %>
            <li>
              <%= link_to "https://github.com/#{@user.github_username}",
                    class: "text-indigo-600 hover:text-indigo-800 underline" do %>
                GitHub: <%= @user.github_username %>
              <% end %>
            </li>
          <% end %>

          <% if @user.linkedin_username.present? %>
            <li>
              <%= link_to "https://linkedin.com/in/#{@user.linkedin_username}",
                    class: "text-indigo-600 hover:text-indigo-800 underline" do %>
                LinkedIn: <%= @user.linkedin_username %>
              <% end %>
            </li>
          <% end %>

          <% if @user.portfolio_url.present? %>
            <li>
              <% safe_url = URI.parse(@user.portfolio_url) rescue nil %>
              <% if safe_url&.scheme&.match?(/\Ahttps?\z/) %>
                <%= link_to @user.portfolio_url, safe_url.to_s,
                      class: "text-indigo-600 hover:text-indigo-800 underline" %>
              <% else %>
                <span class="text-gray-700"><%= @user.portfolio_url %></span>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% if authenticated? && Current.user == @user %>
      <div class="mt-6">
        <%= link_to "Edit Profile", edit_profile_path,
              class: "inline-block bg-indigo-600 text-white px-4 py-2 rounded-md hover:bg-indigo-700 transition" %>
      </div>
    <% end %>
  </div>
</div>
