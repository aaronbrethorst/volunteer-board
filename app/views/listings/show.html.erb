<div class="w-full max-w-5xl mx-auto">
  <%# === Hero banner === %>
  <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-slate-800 via-slate-900 to-slate-950 p-8 sm:p-10">
    <div class="absolute inset-0 opacity-[0.07]" style="background-image: radial-gradient(circle at 20% 50%, rgb(251 191 36) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgb(251 191 36) 0%, transparent 40%);"></div>

    <div class="relative">
      <%# Top row: badges + actions %>
      <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
        <div class="flex flex-wrap items-center gap-2">
          <span class="inline-flex items-center rounded-full bg-amber-500/20 border border-amber-400/30 px-3 py-1 text-sm font-semibold text-amber-300">
            <%= @listing.discipline.titleize %>
          </span>
          <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-semibold
            <%= case @listing.status
                when 'open' then 'bg-emerald-500/20 border border-emerald-400/30 text-emerald-300'
                when 'filled' then 'bg-yellow-500/20 border border-yellow-400/30 text-yellow-300'
                when 'closed' then 'bg-red-500/20 border border-red-400/30 text-red-300'
                end %>">
            <%= @listing.status.titleize %>
          </span>
        </div>

        <div class="flex flex-col items-end gap-1.5">
          <div class="flex items-center gap-2">
            <%= render "interests/button", listing: @listing, interested: (authenticated? && Current.user&.interested_listings&.include?(@listing)) %>
            <% if authenticated? %>
              <%= link_to new_listing_flag_path(@listing),
                  class: "inline-flex items-center gap-1 rounded-full bg-white/10 hover:bg-red-500/20 border border-white/10 hover:border-red-400/30 px-3 py-1.5 text-sm text-slate-300 hover:text-red-300 transition-colors" do %>
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v1.5M3 21v-6m0 0 2.77-.693a9 9 0 0 1 6.208.682l.108.054a9 9 0 0 0 6.086.71l3.114-.732a48.524 48.524 0 0 1-.005-10.499l-3.11.732a9 9 0 0 1-6.085-.711l-.108-.054a9 9 0 0 0-6.208-.682L3 4.5M3 15V4.5"/></svg>
                Flag
              <% end %>
            <% end %>
            <% if authenticated? && @listing.organization.memberships.exists?(user: Current.user) %>
              <%= link_to edit_listing_path(@listing),
                  class: "inline-flex items-center gap-1.5 rounded-full bg-amber-500 hover:bg-amber-400 px-4 py-1.5 text-sm font-semibold text-slate-900 shadow-sm transition-colors" do %>
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125"/></svg>
                Edit
              <% end %>
            <% end %>
          </div>
          <% if @listing.interests.count > 0 %>
            <span class="text-xs text-slate-400"><%= pluralize(@listing.interests.count, "person") %> interested</span>
          <% end %>
        </div>
      </div>

      <%# Title + org %>
      <h1 class="text-2xl sm:text-3xl font-bold text-white tracking-tight"><%= @listing.title %></h1>
      <p class="mt-2">
        <%= link_to organization_path(@listing.organization.slug),
            class: "inline-flex items-center gap-2 text-slate-300 hover:text-amber-300 transition-colors" do %>
          <%= render OrganizationLogoComponent.new(organization: @listing.organization, size: :xs, variant: :dark) %>
          <span class="font-medium"><%= @listing.organization.name %></span>
        <% end %>
      </p>

      <%# Metadata pills %>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mt-5 text-sm text-slate-300">
        <% if @listing.commitment.present? %>
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
            <%= @listing.commitment %>
          </span>
        <% end %>
        <% if @listing.location.present? %>
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
            <%= @listing.location %>
          </span>
        <% end %>
      </div>

      <%# Skills %>
      <% if @listing.skills.present? %>
        <div class="flex flex-wrap gap-1.5 mt-4">
          <% @listing.skills.split(",").map(&:strip).each do |skill| %>
            <span class="inline-flex items-center rounded-full bg-white/10 border border-white/10 px-2.5 py-0.5 text-xs font-medium text-slate-300">
              <%= skill %>
            </span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%# === Body content === %>
  <div class="mt-6 bg-white rounded-xl border border-gray-200 shadow-sm p-6 sm:p-8">
    <%# Description %>
    <% if @listing.description.present? %>
      <h2 class="text-lg font-semibold text-gray-900 mb-3">Description</h2>
      <div class="prose max-w-none text-gray-700">
        <%= @listing.description %>
      </div>
    <% end %>

    <%# Interested volunteers link (org owners only) %>
    <% if authenticated? && @listing.organization.memberships.exists?(user: Current.user, role: :owner) %>
      <div class="mt-8">
        <%= link_to listing_interest_details_path(@listing),
            class: "group flex items-center justify-between rounded-lg bg-amber-50 border border-amber-200 p-5 hover:bg-amber-100 hover:border-amber-300 transition-all" do %>
          <div class="flex items-center gap-3">
            <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128H5.228A2 2 0 0 1 3.35 17.33a8.01 8.01 0 0 1 1.926-4.564M12 12.75a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm-6.276 4.023a8.07 8.07 0 0 1 .769-1.773M12 12.75c1.384 0 2.63-.498 3.6-1.324"/></svg>
            <div>
              <p class="font-semibold text-amber-900">Interested Volunteers</p>
              <p class="text-sm text-amber-700"><%= pluralize(@listing.interests.count, "person") %> interested</p>
            </div>
          </div>
          <svg class="w-5 h-5 text-amber-400 group-hover:text-amber-600 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
        <% end %>
      </div>
    <% end %>

    <%# About the org %>
    <div class="mt-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">About the Organization</h2>
      <%= link_to organization_path(@listing.organization.slug),
          class: "group flex items-center gap-4" do %>
        <%= render OrganizationLogoComponent.new(organization: @listing.organization, size: :lg, extra_classes: "group-hover:ring-amber-300 transition-all shadow-sm") %>
        <div>
          <p class="font-semibold text-gray-900 group-hover:text-amber-700 transition-colors">
            <%= @listing.organization.name %>
          </p>
          <% if @listing.organization.description.present? %>
            <p class="text-sm text-gray-500 mt-0.5 line-clamp-2"><%= truncate(@listing.organization.description, length: 150) %></p>
          <% end %>
        </div>
        <svg class="w-5 h-5 text-gray-300 group-hover:text-amber-500 ml-auto shrink-0 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
      <% end %>
    </div>
  </div>
</div>
