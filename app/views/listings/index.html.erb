<div class="w-full">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-gray-900 mb-1">Browse Listings</h1>
      <p class="text-gray-500 text-sm">Find volunteer opportunities that match your skills.</p>
    </div>
    <% if authenticated? %>
      <% owned_orgs = Current.user.memberships.where(role: :owner).includes(:organization).map(&:organization).select(&:kept?) %>
      <% if owned_orgs.size == 1 %>
        <%= link_to new_organization_listing_path(owned_orgs.first.slug), class: "link-button" do %>
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
            New Listing
          </span>
        <% end %>
      <% elsif owned_orgs.size > 1 %>
        <%= link_to profile_organizations_path, class: "link-button" do %>
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
            New Listing
          </span>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <%# Search bar %>
  <div class="mb-8">
    <%= form_with url: listings_path, method: :get, class: "flex flex-col sm:flex-row gap-3" do |f| %>
      <div class="flex-1 relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </div>
        <%= f.text_field :query,
            value: params[:query],
            placeholder: "Search by title, skills, or organization...",
            class: "w-full rounded-lg border border-gray-200 bg-white pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 shadow-sm" %>
      </div>
      <div>
        <%= f.submit "Search",
            class: "w-full sm:w-auto rounded-lg bg-slate-800 px-6 py-2.5 text-sm font-medium text-white hover:bg-slate-700 cursor-pointer transition shadow-sm" %>
      </div>
      <% if params[:query].present? || params[:discipline].present? %>
        <div>
          <%= link_to "Clear", listings_path, class: "inline-flex items-center justify-center w-full sm:w-auto rounded-lg border border-gray-200 bg-white px-5 py-2.5 text-sm font-medium text-gray-600 hover:bg-gray-50 transition shadow-sm" %>
        </div>
      <% end %>
    <% end %>
  </div>

  <div class="flex flex-col lg:flex-row gap-8">
    <%# Discipline sidebar %>
    <aside class="lg:w-56 shrink-0">
      <nav class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
        <h2 class="text-sm font-semibold text-gray-900 mb-3 uppercase tracking-wide">Disciplines</h2>
        <ul class="space-y-1">
          <li>
            <%= link_to "All Disciplines",
                listings_path(query: params[:query]),
                class: "block px-3 py-2 rounded-lg text-sm font-medium #{params[:discipline].blank? ? 'bg-amber-50 text-amber-800' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'}" %>
          </li>
          <% Listing.disciplines.keys.each do |discipline| %>
            <li>
              <%= link_to discipline.titleize,
                  listings_path(discipline: discipline, query: params[:query]),
                  class: "block px-3 py-2 rounded-lg text-sm font-medium #{params[:discipline] == discipline ? 'bg-amber-50 text-amber-800' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'}" %>
            </li>
          <% end %>
        </ul>
      </nav>
    </aside>

    <%# Results %>
    <div class="flex-1">
      <% if @listings.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
          <% @listings.each do |listing| %>
            <%= render ListingCardComponent.new(listing: listing) %>
          <% end %>
        </div>

        <% if @pagy.last > 1 %>
          <div class="mt-10">
            <%== @pagy.series_nav(id: "listings-pagination", aria_label: "Listings pagination") %>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-16 border-2 border-dashed border-gray-200 rounded-xl">
          <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <p class="text-gray-500 text-lg mt-4">No listings found.</p>
          <p class="text-gray-400 text-sm mt-1">Try adjusting your search or filters.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
