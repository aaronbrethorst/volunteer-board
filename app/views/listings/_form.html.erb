<%= form_with(model: listing, url: url, method: method, class: "space-y-6") do |form| %>
  <% if listing.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4">
      <h2 class="text-red-800 font-semibold mb-2"><%= pluralize(listing.errors.count, "error") %> prevented this listing from being saved:</h2>
      <ul class="list-disc list-inside text-red-700 text-sm">
        <% listing.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= render Form::TextFieldComponent.new(form: form, attribute: :title) %>

  <%= render Form::SelectComponent.new(form: form, attribute: :discipline, choices: Listing.disciplines.keys.map { |d| [d.titleize, d] }, prompt: "Select a discipline") %>

  <div>
    <%= form.label :description, class: "form-label" %>
    <%= form.rich_text_area :description, class: "w-full" %>
  </div>

  <%= render Form::TextFieldComponent.new(form: form, attribute: :commitment, placeholder: "e.g. ~5 hrs/week, One-time project, Flexible") %>

  <%= render Form::TextFieldComponent.new(form: form, attribute: :location, placeholder: "Remote") %>

  <%= render Form::TextFieldComponent.new(form: form, attribute: :skills, placeholder: "e.g. Ruby, Rails, React") %>

  <%= render Form::SelectComponent.new(form: form, attribute: :status, choices: Listing.statuses.keys.map { |s| [s.titleize, s] }) %>

  <div class="flex items-center gap-4">
    <%= render Form::SubmitButtonComponent.new(form: form) %>
    <% if listing.persisted? %>
      <%= link_to "Cancel", listing_path(listing), class: "text-gray-600 hover:text-gray-800" %>
    <% end %>
  </div>
<% end %>
