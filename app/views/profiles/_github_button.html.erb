<div class="flex items-center justify-between py-3">
  <div>
    <p class="font-medium text-gray-900">GitHub</p>
    <% if user.github_linked? %>
      <p class="text-sm text-gray-500">Linked as <strong><%= user.github_username %></strong></p>
    <% else %>
      <p class="text-sm text-gray-500">Not linked</p>
    <% end %>
  </div>
  <div>
    <% if user.github_linked? %>
      <%= button_to "Unlink", "/auth/github", method: :delete,
                    class: "text-red-600 hover:text-red-800 text-sm font-medium" %>
    <% else %>
      <%= button_to "Link GitHub", "/auth/github", method: :post,
                    data: { turbo: false },
                    class: "bg-gray-800 text-white px-3 py-1.5 rounded-md text-sm hover:bg-gray-900 transition cursor-pointer" %>
    <% end %>
  </div>
</div>