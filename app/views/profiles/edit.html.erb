<div class="w-full max-w-2xl mx-auto">
  <div class="bg-white shadow rounded-lg p-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-6">Edit Profile</h1>

    <%= form_with(model: @user, url: profile_path, method: :patch, class: "space-y-6") do |form| %>
      <% if @user.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-md p-4">
          <h2 class="text-red-800 font-semibold mb-2"><%= pluralize(@user.errors.count, "error") %> prevented your profile from being saved:</h2>
          <ul class="list-disc list-inside text-red-700 text-sm">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :name, class: "w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= form.label :bio, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_area :bio, rows: 5, class: "w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= form.label :portfolio_url, "Portfolio URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.url_field :portfolio_url, class: "w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: "https://yoursite.com" %>
      </div>

      <div class="flex items-center gap-4">
        <%= form.submit "Save Changes", class: "bg-indigo-600 text-white px-4 py-2 rounded-md hover:bg-indigo-700 transition cursor-pointer" %>
        <%= link_to "Cancel", user_path(@user), class: "text-gray-600 hover:text-gray-800" %>
      </div>
    <% end %>
  </div>

  <div class="bg-white shadow rounded-lg p-8 mt-6">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Linked Accounts</h2>

    <div class="space-y-4">
      <%# GitHub %>
      <div class="flex items-center justify-between py-3 border-b border-gray-200">
        <div>
          <p class="font-medium text-gray-900">GitHub</p>
          <% if @user.github_linked? %>
            <p class="text-sm text-gray-500">Linked as <strong><%= @user.github_username %></strong></p>
          <% else %>
            <p class="text-sm text-gray-500">Not linked</p>
          <% end %>
        </div>
        <div>
          <% if @user.github_linked? %>
            <%= button_to "Unlink", "/auth/github", method: :delete,
                  class: "text-red-600 hover:text-red-800 text-sm font-medium" %>
          <% else %>
            <%= button_to "Link GitHub", "/auth/github", method: :post,
                  class: "bg-gray-800 text-white px-3 py-1.5 rounded-md text-sm hover:bg-gray-900 transition cursor-pointer" %>
          <% end %>
        </div>
      </div>

      <%# LinkedIn %>
      <div class="flex items-center justify-between py-3">
        <div>
          <p class="font-medium text-gray-900">LinkedIn</p>
          <% if @user.linkedin_linked? %>
            <p class="text-sm text-gray-500">Linked as <strong><%= @user.linkedin_username %></strong></p>
          <% else %>
            <p class="text-sm text-gray-500">Not linked</p>
          <% end %>
        </div>
        <div>
          <% if @user.linkedin_linked? %>
            <%= button_to "Unlink", "/auth/linkedin", method: :delete,
                  class: "text-red-600 hover:text-red-800 text-sm font-medium" %>
          <% else %>
            <%= button_to "Link LinkedIn", "/auth/linkedin", method: :post,
                  class: "bg-blue-700 text-white px-3 py-1.5 rounded-md text-sm hover:bg-blue-800 transition cursor-pointer" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
