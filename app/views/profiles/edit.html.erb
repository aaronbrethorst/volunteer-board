<div class="w-full max-w-2xl mx-auto">
  <div class="bg-white shadow rounded-lg p-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-6">Edit Profile</h1>

    <%= form_with(model: @user, url: profile_path, method: :patch, class: "space-y-6") do |form| %>
      <% if @user.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-md p-4">
          <h2 class="text-red-800 font-semibold mb-2"><%= pluralize(@user.errors.count, "error") %> prevented your profile from being saved:</h2>
          <ul class="list-disc list-inside text-red-700 text-sm">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= render Form::TextFieldComponent.new(form: form, attribute: :name) %>

      <%= render Form::TextAreaComponent.new(form: form, attribute: :bio, rows: 5) %>

      <%= render Form::UrlFieldComponent.new(form: form, attribute: :portfolio_url, label: "Portfolio URL", placeholder: "https://yoursite.com") %>

      <div class="flex items-center gap-4">
        <%= render Form::SubmitButtonComponent.new(form: form, label: "Save Changes") %>
        <%= link_to "Cancel", user_path(@user), class: "text-gray-600 hover:text-gray-800" %>
      </div>
    <% end %>
  </div>

  <div class="bg-white shadow rounded-lg p-8 mt-6">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Linked Accounts</h2>

    <div class="space-y-4">
      <%= render 'profiles/github_button', user: @user %>
      <%#= render 'profiles/linkedin_button', user: @user %>
    </div>
  </div>
</div>
