<div class="w-full max-w-4xl mx-auto">
  <div class="bg-white shadow rounded-lg p-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-6">Applied Listings</h1>

    <% if @interested_listings.any? %>
      <ul class="divide-y divide-gray-200">
        <% @interested_listings.each do |listing| %>
          <li class="py-4">
            <div class="flex items-start justify-between">
              <div>
                <h3 class="text-lg font-medium">
                  <%= link_to listing.title, listing_path(listing), class: "link" %>
                </h3>
                <p class="text-sm text-gray-600 mt-1">
                  <%= link_to listing.organization.name, organization_path(listing.organization.slug), class: "text-gray-500 hover:text-gray-700" %>
                </p>
                <div class="flex items-center gap-3 mt-2">
                  <span class="inline-flex items-center rounded-full bg-indigo-100 px-2.5 py-0.5 text-xs font-medium text-indigo-800">
                    <%= listing.discipline.titleize %>
                  </span>
                  <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
                    <%= case listing.status
                        when 'open' then 'bg-green-100 text-green-800'
                        when 'filled' then 'bg-yellow-100 text-yellow-800'
                        when 'closed' then 'bg-red-100 text-red-800'
                        end %>">
                    <%= listing.status.titleize %>
                  </span>
                  <% if listing.location.present? %>
                    <span class="text-xs text-gray-500"><%= listing.location %></span>
                  <% end %>
                </div>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-gray-500">You haven't applied to any listings yet. Browse the <%= link_to "listings", listings_path, class: "link" %> to find opportunities.</p>
    <% end %>
  </div>
</div>
