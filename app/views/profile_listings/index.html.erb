<div class="w-full max-w-5xl mx-auto">
  <%# === Header === %>
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">My Applications</h1>
    <p class="text-gray-500 text-sm mt-1">Listings you've expressed interest in.</p>
  </div>

  <% if @interested_listings.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      <% @interested_listings.each do |listing| %>
        <%= render ListingCardComponent.new(listing: listing) %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 border-2 border-dashed border-gray-200 rounded-xl">
      <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/></svg>
      <p class="text-gray-500 text-lg mt-4">No applications yet.</p>
      <p class="text-gray-400 text-sm mt-1">Browse the <%= link_to "listings", root_path(anchor: "opportunities"), class: "link" %> to find opportunities.</p>
    </div>
  <% end %>
</div>
