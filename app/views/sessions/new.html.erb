<div class="flex min-h-full flex-col justify-center px-6 py-12 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-sm mt-10">
    <h1 class="text-2xl mb-8 text-center">
        <span class="text-slate-800 press-start-2p">OSS<span class="text-amber-600">Volunteers</span></span>
    </h1>
    <h2 class="text-center text-2xl/9 font-bold tracking-tight text-gray-900">Sign in to your account</h2>
  </div>

  <div class="mt-10 sm:mx-auto sm:w-full sm:max-w-sm">
    <%= form_with url: session_url, class: "space-y-6" do |form| %>
      <% if notice = flash[:notice] %>
        <% flash.delete(:notice) %>
        <div class="rounded-md bg-blue-50 border border-blue-200 p-3">
          <p class="text-sm font-medium text-blue-800"><%= notice %></p>
        </div>
      <% end %>

      <% if alert = flash[:alert] %>
        <% flash.delete(:alert) %>
        <div class="rounded-md bg-red-50 border border-red-200 p-3">
          <p class="text-sm font-medium text-red-800"><%= alert %></p>
        </div>
      <% end %>

      <%= render Form::EmailFieldComponent.new(form: form, attribute: :email_address, label: "Email address", required: true, autofocus: true, autocomplete: "username", value: params[:email_address]) %>

      <%= render Form::PasswordFieldComponent.new(form: form, attribute: :password, required: true, autocomplete: "current-password", maxlength: 72) %>

      <%= render Form::SubmitButtonComponent.new(form: form, label: "Sign in") %>
    <% end %>

    <p class="mt-10 text-center text-sm/6 text-gray-500">
      Don't have an account?
      <%= link_to "Sign up", new_registration_path, class: "link font-semibold" %>
    </p>
    <p class="mt-2 text-center text-sm/6">
      <%= link_to "Forgot password?", new_password_path, class: "link font-semibold" %>
    </p>
  </div>
</div>
