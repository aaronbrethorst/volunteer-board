<% content_for(:title, "Report #{@flaggable.respond_to?(:name) ? @flaggable.name : @flaggable.title}") %>

<div class="w-full max-w-lg mx-auto">
  <div class="bg-white shadow rounded-lg p-8">
    <h1 class="text-2xl font-bold text-gray-900 mb-2">Report Content</h1>
    <p class="text-gray-600 mb-6">
      You are reporting
      <strong><%= @flaggable.respond_to?(:name) ? @flaggable.name : @flaggable.title %></strong>.
    </p>

    <%= form_with model: @flag, url: flag_form_url do |f| %>
      <% if @flag.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-md p-4 mb-6">
          <ul class="list-disc list-inside text-sm text-red-600">
            <% @flag.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= render Form::TextAreaComponent.new(form: f, attribute: :reason, label: "Reason for reporting", rows: 4, required: true, placeholder: "Please describe why you are reporting this content...", autofocus: true) %>

      <div class="flex items-center gap-3 mt-6">
        <%= render Form::SubmitButtonComponent.new(form: f, label: "Submit Report", variant: :danger) %>
        <%= link_to "Cancel", :back, class: "text-sm text-gray-600 hover:text-gray-800" %>
      </div>
    <% end %>
  </div>
</div>
