<div class="w-full max-w-4xl mx-auto space-y-8">
  <div class="bg-white shadow rounded-lg p-8">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-3xl font-bold text-gray-900">My Organizations</h1>
      <%= link_to "New Organization", new_organization_path, class: "bg-slate-800 text-white hover:bg-slate-700 px-4 py-2 text-sm font-medium rounded-md" %>
    </div>

    <% if @organizations.any? %>
      <ul class="divide-y divide-gray-200">
        <% @organizations.each do |organization| %>
          <li class="py-4">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-4">
                <% if organization.logo.attached? %>
                  <%= image_tag organization.logo, class: "h-10 w-10 rounded-full object-cover" %>
                <% else %>
                  <div class="h-10 w-10 rounded-full bg-indigo-100 flex items-center justify-center">
                    <span class="text-indigo-700 font-semibold text-sm"><%= organization.name.first.upcase %></span>
                  </div>
                <% end %>
                <div>
                  <h3 class="text-lg font-medium">
                    <%= link_to organization.name, organization_path(organization.slug), class: "text-indigo-600 hover:text-indigo-800" %>
                  </h3>
                </div>
              </div>
              <% membership = Current.user.memberships.find_by(organization: organization) %>
              <% if membership&.owner? %>
                <div class="flex items-center gap-3">
                  <%= link_to "New Listing", new_organization_listing_path(organization.slug), class: "text-sm text-indigo-600 hover:text-indigo-800" %>
                  <%= link_to "Edit", edit_organization_path(organization.slug), class: "text-sm text-gray-500 hover:text-gray-700" %>
                </div>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-gray-500">You don't belong to any organizations yet. <%= link_to "Create one", new_organization_path, class: "text-indigo-600 hover:text-indigo-800" %> to get started.</p>
    <% end %>
  </div>

  <div class="bg-white shadow rounded-lg p-8">
    <div class="flex items-center justify-between">
      <h2 class="text-xl font-semibold text-gray-900">Applied Listings</h2>
      <%= link_to "View All", profile_listings_path, class: "text-sm text-indigo-600 hover:text-indigo-800 font-medium" %>
    </div>
  </div>
</div>
