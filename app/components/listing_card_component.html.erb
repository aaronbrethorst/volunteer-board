<%= link_to listing_path(@listing), class: "group block rounded-xl border border-gray-200 bg-white p-6 shadow-sm hover:shadow-md hover:border-gray-300 transition-all duration-200" do %>
  <div class="flex items-start justify-between mb-3">
    <span class="inline-block rounded-md bg-amber-50 border border-amber-200 px-2.5 py-0.5 text-xs font-semibold text-amber-800">
      <%= @listing.discipline.titleize %>
    </span>
    <span class="text-xs text-gray-400"><%= time_ago_in_words(@listing.created_at) %> ago</span>
  </div>

  <h3 class="text-base font-semibold text-gray-900 group-hover:text-amber-700 transition-colors mb-1 line-clamp-2">
    <%= @listing.title %>
  </h3>
  <p class="text-sm text-gray-500 mb-3">
    <%= @listing.organization.name %>
  </p>

  <div class="space-y-1 text-sm text-gray-600 mb-3">
    <% if @listing.commitment.present? %>
      <p class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <%= @listing.commitment %>
      </p>
    <% end %>
    <% if @listing.location.present? %>
      <p class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        <%= @listing.location %>
      </p>
    <% end %>
  </div>

  <% if @listing.skills.present? %>
    <div class="flex flex-wrap gap-1.5">
      <% @listing.skills.split(",").map(&:strip).first(4).each do |skill| %>
        <span class="inline-block rounded-full bg-slate-100 px-2.5 py-0.5 text-xs text-slate-600"><%= skill %></span>
      <% end %>
      <% remaining = @listing.skills.split(",").size - 4 %>
      <% if remaining > 0 %>
        <span class="inline-block rounded-full bg-slate-100 px-2.5 py-0.5 text-xs text-slate-400">+<%= remaining %></span>
      <% end %>
    </div>
  <% end %>
<% end %>
